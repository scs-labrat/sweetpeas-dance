{
  "name": "CommunityComment",
  "type": "object",
  "properties": {
    "post_id": {
      "type": "string",
      "description": "ID of the CommunityPost this comment belongs to"
    },
    "author_email": {
      "type": "string",
      "format": "email",
      "description": "Email of the comment author"
    },
    "author_name": {
      "type": "string",
      "description": "Display name of the author"
    },
    "content": {
      "type": "string",
      "description": "Comment text"
    }
  },
  "required": [
    "post_id",
    "author_email",
    "content"
  ]
}
