{
  "name": "DancerProfile",
  "type": "object",
  "properties": {
    "parent_email": {
      "type": "string",
      "format": "email",
      "description": "Email of the parent/guardian user who manages this dancer"
    },
    "name": {
      "type": "string",
      "description": "Dancer's full name"
    },
    "birthdate": {
      "type": "string",
      "format": "date",
      "description": "Dancer's date of birth"
    },
    "skill_level": {
      "type": "string",
      "enum": [
        "beginner",
        "intermediate",
        "advanced"
      ],
      "default": "beginner",
      "description": "Dancer's current skill level"
    },
    "notes": {
      "type": "string",
      "description": "Special needs, allergies, or other notes"
    },
    "avatar_url": {
      "type": "string",
      "description": "Profile photo URL"
    },
    "achievements": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Free-text achievements or milestones, e.g. 'Danced in the 2025 Spring Recital'"
    }
  },
  "required": [
    "parent_email",
    "name"
  ],
  "rls": {
    "read": {},
    "write": {},
    "update": {},
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}